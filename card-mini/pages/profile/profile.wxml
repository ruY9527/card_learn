<!--pages/profile/profile.wxml-->
<view class="container">
  <!-- 冲刺倒计时 -->
  <view class="sprint-section" wx:if="{{sprintConfig.enabled && sprintConfig.examDate && !sprintConfig.isExpired}}">
    <view class="sprint-card">
      <view class="sprint-header">
        <text class="sprint-title">{{sprintConfig.examName}}</text>
        <text class="sprint-date">考试日期：{{sprintConfig.examDate}}</text>
      </view>
      <view class="sprint-countdown">
        <view class="countdown-number">{{sprintConfig.daysRemaining}}</view>
        <view class="countdown-label">天</view>
      </view>
      <view class="sprint-tip">坚持复习，冲刺成功！</view>
    </view>
  </view>

  <!-- 用户信息卡片 -->
  <view class="user-section card" bindtap="handleUserCardClick">
    <view class="user-info">
      <view class="avatar {{isLoggedIn ? 'logged-in' : ''}}">
        <text class="avatar-text">{{isLoggedIn ? userInfo.nickname[0] : '游'}}</text>
      </view>
      <view class="user-detail">
        <text class="user-name">{{isLoggedIn ? userInfo.nickname : '游客模式'}}</text>
        <text class="user-status">{{isLoggedIn ? '已登录' : '点击登录保存学习进度'}}</text>
      </view>
    </view>
    <!-- 退出按钮 -->
    <view class="logout-btn" wx:if="{{isLoggedIn}}" catchtap="logout">
      <text class="logout-text">退出</text>
    </view>
  </view>

  <!-- 学习统计 -->
  <view class="stats-section">
    <view class="section-title">学习统计</view>
    <view class="stats-grid">
      <view class="stat-item card" bindtap="goToProgressCards" data-type="learned">
        <text class="stat-value text-primary">{{stats.learned}}</text>
        <text class="stat-label">已学习</text>
        <text class="stat-tip">点击查看</text>
      </view>
      <view class="stat-item card" bindtap="goToProgressCards" data-type="mastered">
        <text class="stat-value text-success">{{stats.mastered}}</text>
        <text class="stat-label">已掌握</text>
        <text class="stat-tip">点击查看</text>
      </view>
      <view class="stat-item card" bindtap="goToProgressCards" data-type="review">
        <text class="stat-value text-warning">{{stats.review}}</text>
        <text class="stat-label">待复习</text>
        <text class="stat-tip">点击查看</text>
      </view>
    </view>
  </view>

  <!-- 学习历史 -->
  <view class="history-section" wx:if="{{historyList.length > 0}}">
    <view class="section-title">最近学习</view>
    <view class="history-list">
      <view class="history-item card" wx:for="{{historyList}}" wx:key="id">
        <view class="history-header">
          <text class="subject-name">{{item.subjectName}}</text>
          <text class="history-time">{{item.time}}</text>
        </view>
        <view class="history-progress">
          <view class="progress-track">
            <view class="progress-fill" style="width: {{item.progress}}%"></view>
          </view>
          <text class="progress-percent">{{item.progress}}%</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置 -->
  <view class="settings-section">
    <view class="section-title">设置</view>
    <view class="settings-list">
      <view class="setting-item card" bindtap="handleSetting" data-key="notification">
        <text class="setting-label">学习提醒</text>
        <switch checked="{{settings.notification}}" color="#409EFF" />
      </view>
      <view class="setting-item card" bindtap="handleSetting" data-key="sound">
        <text class="setting-label">音效</text>
        <switch checked="{{settings.sound}}" color="#409EFF" />
      </view>
      <view class="setting-item card" bindtap="handleClearCache">
        <text class="setting-label">清除缓存</text>
        <text class="cache-size">12KB</text>
      </view>
    </view>
  </view>

  <!-- 反馈入口 -->
  <view class="feedback-section">
    <view class="section-title">帮助与反馈</view>
    <view class="feedback-list">
      <view class="feedback-item card" bindtap="goFeedback">
        <view class="feedback-icon">📝</view>
        <text class="feedback-label">提交反馈</text>
        <text class="feedback-arrow">→</text>
      </view>
      <view class="feedback-item card" bindtap="goFeedbackList" wx:if="{{isLoggedIn}}">
        <view class="feedback-icon">📋</view>
        <text class="feedback-label">我的反馈记录</text>
        <text class="feedback-arrow">→</text>
      </view>
    </view>
  </view>
</view>

<!-- 登录弹窗 -->
<view class="modal-mask" wx:if="{{showLoginModal}}" bindtap="hideLoginModal"></view>
<view class="login-modal" wx:if="{{showLoginModal}}">
  <!-- 头部装饰 -->
  <view class="modal-header-decoration">
    <view class="decoration-circle circle-1"></view>
    <view class="decoration-circle circle-2"></view>
    <view class="decoration-circle circle-3"></view>
  </view>
  
  <!-- 关闭按钮 -->
  <view class="modal-close-btn" catchtap="hideLoginModal">
    <text class="close-icon">✕</text>
  </view>

  <!-- 标题区域 -->
  <view class="modal-title-area">
    <view class="title-icon">
      <text>🔐</text>
    </view>
    <text class="modal-title">欢迎登录</text>
    <text class="modal-subtitle">登录后可保存学习进度并提交反馈</text>
  </view>

  <!-- 表单区域 -->
  <view class="modal-body">
    <!-- 账号输入 -->
    <view class="input-group">
      <view class="input-wrapper">
        <view class="input-icon">
          <text>👤</text>
        </view>
        <input
          class="input-field"
          type="text"
          placeholder="请输入账号"
          placeholder-class="input-placeholder"
          value="{{username}}"
          bindinput="onUsernameInput"
          bindfocus="onInputFocus"
          bindblur="onInputBlur"
          data-field="username"
        />
        <view class="input-clear" wx:if="{{username}}" catchtap="clearUsername">
          <text>✕</text>
        </view>
      </view>
    </view>

    <!-- 密码输入 -->
    <view class="input-group">
      <view class="input-wrapper">
        <view class="input-icon">
          <text>🔑</text>
        </view>
        <input
          class="input-field"
          type="{{showPassword ? 'text' : 'password'}}"
          placeholder="请输入密码"
          placeholder-class="input-placeholder"
          value="{{password}}"
          bindinput="onPasswordInput"
          bindfocus="onInputFocus"
          bindblur="onInputBlur"
          data-field="password"
        />
        <view class="input-toggle" catchtap="togglePassword">
          <text>{{showPassword ? '🙈' : '👁️'}}</text>
        </view>
      </view>
    </view>

    <!-- 验证码 -->
    <view class="input-group captcha-group">
      <view class="captcha-wrapper">
        <view class="input-wrapper captcha-input-wrapper">
          <view class="input-icon">
            <text>🔢</text>
          </view>
          <input
            class="input-field captcha-input"
            type="text"
            placeholder="请输入验证码"
            placeholder-class="input-placeholder"
            value="{{captcha}}"
            bindinput="onCaptchaInput"
            maxlength="4"
          />
        </view>
        <view class="captcha-box" catchtap="refreshCaptcha">
          <image
            class="captcha-image"
            src="{{captchaImage}}"
            mode="aspectFit"
            wx:if="{{captchaImage}}"
          />
          <view class="captcha-loading" wx:else>
            <view class="loading-spinner"></view>
            <text>加载中</text>
          </view>
        </view>
      </view>
      <view class="captcha-refresh" catchtap="refreshCaptcha">
        <text class="refresh-icon">🔄</text>
        <text class="refresh-text">点击刷新验证码</text>
      </view>
    </view>
  </view>

  <!-- 按钮区域 -->
  <view class="modal-footer">
    <button 
      class="login-btn {{loginLoading ? 'loading' : ''}} {{canSubmit ? '' : 'disabled'}}" 
      bindtap="doLogin"
      disabled="{{loginLoading || !canSubmit}}"
    >
      <view class="btn-content">
        <view class="loading-icon" wx:if="{{loginLoading}}"></view>
        <text>{{loginLoading ? '登录中...' : '立即登录'}}</text>
      </view>
    </button>
  </view>

  <!-- 底部提示 -->
  <view class="modal-bottom">
    <text class="bottom-tip">首次登录请联系管理员获取账号</text>
  </view>
</view>