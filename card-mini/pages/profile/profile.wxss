/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 32rpx;
  padding-bottom: 100rpx;
}

/* 冲刺倒计时区域 */
.sprint-section {
  margin-bottom: 32rpx;
}

.sprint-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 24rpx;
  color: #FFFFFF;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sprint-header {
  text-align: center;
  margin-bottom: 16rpx;
}

.sprint-title {
  font-size: 28rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 8rpx;
}

.sprint-date {
  font-size: 22rpx;
  opacity: 0.8;
}

.sprint-countdown {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin: 16rpx 0;
}

.countdown-number {
  font-size: 72rpx;
  font-weight: bold;
  line-height: 1;
}

.countdown-label {
  font-size: 28rpx;
  margin-left: 12rpx;
}

.sprint-tip {
  font-size: 22rpx;
  opacity: 0.9;
  margin-top: 8rpx;
}

/* 卡片基础样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 用户信息区域 */
.user-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #409EFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar.logged-in {
  background-color: #67C23A;
}

.avatar-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
}

.user-detail {
  margin-left: 24rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #303133;
  display: block;
}

.user-status {
  font-size: 26rpx;
  color: #909399;
  margin-top: 8rpx;
  display: block;
}

.logout-btn {
  padding: 12rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.logout-text {
  font-size: 26rpx;
  color: #909399;
}

/* 统计区域 */
.stats-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.stat-item:active {
  transform: scale(0.95);
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
}

.stat-value.text-primary {
  color: #409EFF;
}

.stat-value.text-success {
  color: #67C23A;
}

.stat-value.text-warning {
  color: #E6A23C;
}

.stat-label {
  font-size: 26rpx;
  color: #909399;
  margin-top: 8rpx;
}

.stat-tip {
  font-size: 22rpx;
  color: #c0c4cc;
  margin-top: 4rpx;
}

/* 学习历史 */
.history-section {
  margin-bottom: 32rpx;
}

.history-list {
  margin-top: 16rpx;
}

.history-item {
  margin-bottom: 16rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.subject-name {
  font-size: 28rpx;
  color: #303133;
}

.history-time {
  font-size: 24rpx;
  color: #909399;
}

.history-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.progress-track {
  flex: 1;
  height: 8rpx;
  background-color: #F5F5F5;
  border-radius: 4rpx;
}

.progress-fill {
  height: 100%;
  background-color: #409EFF;
  border-radius: 4rpx;
}

.progress-percent {
  font-size: 24rpx;
  color: #409EFF;
}

/* 设置区域 */
.settings-section {
  margin-bottom: 32rpx;
}

.settings-list {
  margin-top: 16rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #303133;
}

.cache-size {
  font-size: 26rpx;
  color: #909399;
}

/* 反馈区域 */
.feedback-section {
  margin-bottom: 32rpx;
}

.feedback-list {
  margin-top: 16rpx;
}

.feedback-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.feedback-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.feedback-label {
  font-size: 30rpx;
  color: #303133;
  flex: 1;
}

.feedback-arrow {
  font-size: 28rpx;
  color: #909399;
}

/* ========== 登录弹窗样式 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
  z-index: 1000;
}

.login-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 88%;
  max-width: 640rpx;
  background-color: #FFFFFF;
  border-radius: 32rpx;
  z-index: 1001;
  overflow: hidden;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
}

/* 头部装饰 */
.modal-header-decoration {
  height: 120rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  position: relative;
  overflow: hidden;
}

.decoration-circle {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.1);
}

.circle-1 {
  width: 200rpx;
  height: 200rpx;
  top: -80rpx;
  left: -40rpx;
}

.circle-2 {
  width: 150rpx;
  height: 150rpx;
  top: -60rpx;
  right: 20rpx;
}

.circle-3 {
  width: 100rpx;
  height: 100rpx;
  bottom: -50rpx;
  left: 50%;
}

/* 关闭按钮 */
.modal-close-btn {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  width: 56rpx;
  height: 56rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.close-icon {
  color: #fff;
  font-size: 28rpx;
}

/* 标题区域 */
.modal-title-area {
  padding: 40rpx 40rpx 30rpx;
  text-align: center;
  margin-top: -20rpx;
  position: relative;
  z-index: 5;
}

.title-icon {
  width: 80rpx;
  height: 80rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.3);
}

.title-icon text {
  font-size: 40rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #303133;
  display: block;
}

.modal-subtitle {
  font-size: 26rpx;
  color: #909399;
  margin-top: 12rpx;
  display: block;
}

/* 表单区域 */
.modal-body {
  padding: 20rpx 40rpx 30rpx;
}

.input-group {
  margin-bottom: 28rpx;
}

.input-wrapper {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 16rpx;
  padding: 0 20rpx;
  height: 96rpx;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.input-wrapper:focus-within {
  background: #fff;
  border-color: #667eea;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.15);
}

.input-icon {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-icon text {
  font-size: 32rpx;
}

.input-field {
  flex: 1;
  height: 96rpx;
  padding: 0 16rpx;
  font-size: 30rpx;
  color: #303133;
}

.input-placeholder {
  color: #c0c4cc;
}

.input-clear,
.input-toggle {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.input-clear text,
.input-toggle text {
  font-size: 28rpx;
  color: #909399;
}

/* 验证码区域 */
.captcha-group {
  margin-bottom: 20rpx;
}

.captcha-wrapper {
  display: flex;
  gap: 20rpx;
}

.captcha-input-wrapper {
  flex: 1;
}

.captcha-input {
  flex: 1;
}

.captcha-box {
  width: 180rpx;
  height: 96rpx;
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #e4e7ed;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}

.captcha-image {
  width: 160rpx;
  height: 80rpx;
}

.captcha-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.captcha-loading text {
  font-size: 24rpx;
  color: #909399;
}

.loading-spinner {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid #e4e7ed;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.captcha-refresh {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  margin-top: 16rpx;
  padding: 12rpx 0;
}

.refresh-icon {
  font-size: 24rpx;
}

.refresh-text {
  font-size: 24rpx;
  color: #667eea;
}

/* 按钮区域 */
.modal-footer {
  padding: 20rpx 40rpx 30rpx;
}

.login-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.login-btn::after {
  border: none;
}

.login-btn.disabled {
  background: #c0c4cc;
}

.login-btn.loading {
  opacity: 0.8;
}

.btn-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-icon {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

/* 底部提示 */
.modal-bottom {
  padding: 20rpx 40rpx 40rpx;
  text-align: center;
}

.bottom-tip {
  font-size: 24rpx;
  color: #c0c4cc;
}