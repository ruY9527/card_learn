/* pages/profile/profile.wxss */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding: 32rpx;
  padding-bottom: 100rpx;
}

/* 卡片基础样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 用户信息区域 */
.user-section {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background-color: #409EFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar.logged-in {
  background-color: #67C23A;
}

.avatar-text {
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
}

.user-detail {
  margin-left: 24rpx;
}

.user-name {
  font-size: 34rpx;
  font-weight: 600;
  color: #303133;
  display: block;
}

.user-status {
  font-size: 26rpx;
  color: #909399;
  margin-top: 8rpx;
  display: block;
}

.logout-btn {
  padding: 12rpx 24rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.logout-text {
  font-size: 26rpx;
  color: #909399;
}

/* 统计区域 */
.stats-section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #303133;
  margin-bottom: 20rpx;
}

.stats-grid {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 600;
  display: block;
}

.stat-value.text-primary {
  color: #409EFF;
}

.stat-value.text-success {
  color: #67C23A;
}

.stat-value.text-warning {
  color: #E6A23C;
}

.stat-label {
  font-size: 26rpx;
  color: #909399;
  margin-top: 8rpx;
}

/* 学习历史 */
.history-section {
  margin-bottom: 32rpx;
}

.history-list {
  margin-top: 16rpx;
}

.history-item {
  margin-bottom: 16rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.subject-name {
  font-size: 28rpx;
  color: #303133;
}

.history-time {
  font-size: 24rpx;
  color: #909399;
}

.history-progress {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 12rpx;
}

.progress-track {
  flex: 1;
  height: 8rpx;
  background-color: #F5F5F5;
  border-radius: 4rpx;
}

.progress-fill {
  height: 100%;
  background-color: #409EFF;
  border-radius: 4rpx;
}

.progress-percent {
  font-size: 24rpx;
  color: #409EFF;
}

/* 设置区域 */
.settings-section {
  margin-bottom: 32rpx;
}

.settings-list {
  margin-top: 16rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.setting-label {
  font-size: 30rpx;
  color: #303133;
}

.cache-size {
  font-size: 26rpx;
  color: #909399;
}

/* ========== 登录弹窗样式 ========== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  z-index: 1000;
}

.login-modal {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 85%;
  max-width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  z-index: 1001;
  overflow: hidden;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid #EBEEF5;
}

.modal-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #303133;
}

.modal-close {
  width: 44rpx;
  height: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.close-icon {
  color: #909399;
  font-size: 32rpx;
}

.modal-body {
  padding: 30rpx;
}

.input-group {
  margin-bottom: 24rpx;
}

.input-label {
  font-size: 28rpx;
  color: #606266;
  display: block;
  margin-bottom: 12rpx;
}

.input-field {
  width: 100%;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #DCDFE6;
  border-radius: 8rpx;
  font-size: 30rpx;
  color: #303133;
  background-color: #F5F5F5;
}

.input-field:focus {
  border-color: #409EFF;
  background-color: #FFFFFF;
}

/* 验证码区域 */
.captcha-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.captcha-input {
  flex: 1;
  height: 80rpx;
  padding: 0 20rpx;
  border: 1rpx solid #DCDFE6;
  border-radius: 8rpx;
  font-size: 30rpx;
  background-color: #F5F5F5;
}

.captcha-box {
  width: 200rpx;
  height: 80rpx;
  border: 1rpx solid #DCDFE6;
  border-radius: 8rpx;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
}

.captcha-image {
  width: 180rpx;
  height: 70rpx;
}

.captcha-loading {
  font-size: 24rpx;
  color: #909399;
}

.captcha-tip {
  font-size: 24rpx;
  color: #409EFF;
  margin-top: 12rpx;
  display: block;
}

/* 弹窗底部按钮 */
.modal-footer {
  display: flex;
  padding: 24rpx 30rpx;
  gap: 20rpx;
  border-top: 1rpx solid #EBEEF5;
}

.cancel-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.cancel-btn text {
  font-size: 30rpx;
  color: #606266;
}

.confirm-btn {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #409EFF;
  border-radius: 8rpx;
}

.confirm-btn.disabled {
  background-color: #A0CFFF;
}

.confirm-btn text {
  font-size: 30rpx;
  color: #FFFFFF;
}