.my-cards-page {
  min-height: 100vh;
  padding: 32rpx;
  background: #f5f6f8;
}

.empty-tip,
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 32rpx;
  text-align: center;
}

.empty-icon {
  font-size: 88rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #303133;
  font-weight: 500;
}

.empty-desc {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: #909399;
  line-height: 1.6;
}

.login-btn,
.add-btn {
  margin-top: 32rpx;
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
  color: #ffffff;
  border: none;
  border-radius: 40rpx;
  padding: 22rpx 72rpx;
  font-size: 28rpx;
}

.stats-panel {
  background: linear-gradient(135deg, #1f7cf0 0%, #34b3ff 100%);
  border-radius: 24rpx;
  padding: 28rpx;
  color: #ffffff;
  box-shadow: 0 14rpx 36rpx rgba(52, 179, 255, 0.22);
}

.stats-header {
  margin-bottom: 24rpx;
}

.panel-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
}

.panel-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
}

.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.stat-card {
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 18rpx;
  padding: 22rpx;
}

.stat-value {
  display: block;
  font-size: 42rpx;
  font-weight: 700;
}

.stat-label {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
}

.status-tabs {
  white-space: nowrap;
  margin: 28rpx 0 20rpx;
}

.status-tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #606266;
  font-size: 26rpx;
  border: 1rpx solid #ebeef5;
}

.status-tab.active {
  background: #303133;
  color: #ffffff;
  border-color: #303133;
}

.card-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.record-card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.record-header,
.record-meta,
.record-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.subject-badge,
.status-badge {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.subject-badge {
  background: #eef5ff;
  color: #1f6fe5;
}

.status-badge.status-0 {
  background: #fdf6ec;
  color: #e6a23c;
}

.status-badge.status-1 {
  background: #f0f9eb;
  color: #67c23a;
}

.status-badge.status-2 {
  background: #fef0f0;
  color: #f56c6c;
}

.record-title {
  margin-top: 18rpx;
  font-size: 30rpx;
  color: #303133;
  font-weight: 600;
  line-height: 1.5;
}

.record-answer {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: #606266;
  line-height: 1.7;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.record-meta {
  margin-top: 18rpx;
}

.meta-text,
.detail-tip {
  font-size: 22rpx;
  color: #909399;
}

.audit-remark {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #fff7f5;
  color: #c45656;
  font-size: 24rpx;
  line-height: 1.6;
}

.remark-label {
  font-weight: 600;
}

.record-footer {
  margin-top: 20rpx;
}

.delete-action {
  font-size: 24rpx;
  color: #f56c6c;
}

.load-more {
  padding: 32rpx 0 12rpx;
  text-align: center;
  font-size: 26rpx;
  color: #909399;
}
