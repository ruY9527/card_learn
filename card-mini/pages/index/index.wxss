/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 考研倒计时 */
.countdown-bar {
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.countdown-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.countdown-left {
  display: flex;
  flex-direction: column;
}

.countdown-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.countdown-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.countdown-right {
  display: flex;
  align-items: baseline;
}

.countdown-days {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.countdown-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

/* 区域 */
.section {
  margin-top: 32rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #303133;
  margin-bottom: 32rpx;
}

/* 专业列表 */
.major-list {
  display: flex;
  flex-direction: column;
}

.major-item {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.major-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.major-item.active .major-name,
.major-item.active .major-desc {
  color: #fff;
}

.major-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.major-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #303133;
}

.major-desc {
  font-size: 24rpx;
  color: #909399;
}

/* 科目列表 */
.subject-list {
  display: flex;
  flex-wrap: wrap;
}

.subject-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.subject-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.text-white {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.subject-name {
  font-size: 24rpx;
  color: #303133;
}

/* 推荐卡片 */
.card-list {
  display: flex;
  flex-direction: column;
}

.recommend-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-content {
  font-size: 28rpx;
  color: #303133;
  line-height: 1.6;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}

.difficulty {
  font-size: 24rpx;
  color: #909399;
}

.hint {
  font-size: 24rpx;
}

.text-primary {
  color: #409eff;
}

/* 空提示 */
.empty-tip {
  padding: 64rpx;
  text-align: center;
  color: #909399;
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  padding: 64rpx;
  text-align: center;
}