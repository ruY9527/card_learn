/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 120rpx;
}

/* 考研倒计时 */
.countdown-bar {
  padding: 40rpx 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.countdown-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background-color: rgba(255, 255, 255, 0.1);
  border-radius: 16rpx;
  padding: 24rpx 32rpx;
}

.countdown-left {
  display: flex;
  flex-direction: column;
}

.countdown-label {
  font-size: 36rpx;
  font-weight: 600;
  color: #fff;
}

.countdown-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 8rpx;
}

.countdown-right {
  display: flex;
  align-items: baseline;
}

.countdown-days {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
}

.countdown-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

/* 区域 */
.section {
  margin-top: 32rpx;
  padding: 32rpx;
}

.section-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #303133;
  margin-bottom: 32rpx;
}

/* 专业搜索下拉选择器 */
.major-select-container {
  position: relative;
}

.major-select-box {
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  padding: 32rpx;
  border: 2rpx solid #e4e7ed;
}

.select-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.select-value {
  font-size: 32rpx;
  color: #303133;
}

.select-arrow {
  display: flex;
  align-items: center;
}

.arrow-icon {
  font-size: 24rpx;
  color: #909399;
  transition: transform 0.3s;
}

.arrow-up .arrow-icon {
  transform: rotate(180deg);
}

.arrow-down .arrow-icon {
  transform: rotate(0deg);
}

/* 下拉面板 */
.major-picker-panel {
  position: absolute;
  top: 100%;
  left: 0;
  right: 0;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  margin-top: 8rpx;
  z-index: 100;
  max-height: 500rpx;
  overflow: hidden;
}

/* 搜索框 */
.search-box {
  padding: 24rpx;
  border-bottom: 1rpx solid #e4e7ed;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  background-color: #f5f7fa;
  border-radius: 8rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 28rpx;
  color: #909399;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
  background: transparent;
}

.clear-icon {
  font-size: 28rpx;
  color: #909399;
  padding: 8rpx;
}

/* 专业选项列表 */
.major-options-list {
  max-height: 400rpx;
}

.major-option-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 32rpx;
  border-bottom: 1rpx solid #f0f2f5;
}

.major-option-item:last-child {
  border-bottom: none;
}

.major-option-item.selected {
  background-color: #ecf5ff;
}

.option-content {
  display: flex;
  flex-direction: column;
  flex: 1;
}

.option-name {
  font-size: 30rpx;
  color: #303133;
}

.option-desc {
  font-size: 24rpx;
  color: #909399;
  margin-top: 8rpx;
}

.option-check {
  display: flex;
  align-items: center;
  margin-left: 16rpx;
}

.check-icon {
  font-size: 32rpx;
  color: #409eff;
  font-weight: bold;
}

/* 无搜索结果提示 */
.no-result-tip {
  padding: 48rpx;
  text-align: center;
  color: #909399;
  font-size: 28rpx;
}

/* 科目列表 */
.subject-list {
  display: flex;
  flex-wrap: wrap;
}

.subject-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 32rpx;
}

.subject-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.bg-primary {
  background-color: #409eff;
}

.text-white {
  color: #fff;
  font-size: 32rpx;
  font-weight: bold;
}

.subject-name {
  font-size: 24rpx;
  color: #303133;
}

/* 推荐卡片 */
.card-list {
  display: flex;
  flex-direction: column;
}

.recommend-card {
  margin-bottom: 24rpx;
  padding: 32rpx;
  background-color: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  margin-bottom: 16rpx;
}

.subject-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  font-size: 22rpx;
  color: #409eff;
  background-color: #ecf5ff;
  border-radius: 8rpx;
}

.card-content {
  font-size: 28rpx;
  color: #303133;
  line-height: 1.6;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 24rpx;
}

.difficulty {
  font-size: 24rpx;
  color: #909399;
}

.hint {
  font-size: 24rpx;
}

.text-primary {
  color: #409eff;
}

/* 空提示 */
.empty-tip {
  padding: 64rpx;
  text-align: center;
  color: #909399;
  font-size: 28rpx;
}

/* 加载状态 */
.loading {
  padding: 64rpx;
  text-align: center;
}