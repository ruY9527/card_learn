<!--pages/index/index.wxml-->
<view class="container">
  <!-- 考研倒计时 -->
  <view class="countdown-bar" wx:if="{{countdownDays > 0 || sprintConfig.enabled}}">
    <view class="countdown-content">
      <view class="countdown-left">
        <text class="countdown-label">{{countdownText}}</text>
        <text class="countdown-desc">{{sprintConfig.examName || '距离考研还有'}}</text>
      </view>
      <view class="countdown-right">
        <text class="countdown-days">{{countdownDays}}</text>
        <text class="countdown-unit">天</text>
      </view>
    </view>
  </view>

  <!-- 专业分类 - 搜索下拉选择 -->
  <view class="section">
    <view class="section-title">专业分类</view>
    <view class="major-select-container">
      <!-- 选择器触发区域 -->
      <view class="major-select-box" bindtap="toggleMajorPicker">
        <view class="select-content">
          <text class="select-value">{{selectedMajorName || '请选择专业'}}</text>
          <view class="select-arrow {{showMajorPicker ? 'arrow-up' : 'arrow-down'}}">
            <text class="arrow-icon">▼</text>
          </view>
        </view>
      </view>

      <!-- 下拉搜索面板 -->
      <view class="major-picker-panel" wx:if="{{showMajorPicker}}">
        <!-- 搜索输入框 -->
        <view class="search-box">
          <view class="search-input-wrapper">
            <text class="search-icon">🔍</text>
            <input
              class="search-input"
              type="text"
              placeholder="搜索专业名称"
              value="{{majorSearchKeyword}}"
              bindinput="onMajorSearchInput"
              confirm-type="search"
            />
            <text class="clear-icon" wx:if="{{majorSearchKeyword}}" bindtap="clearMajorSearch">✕</text>
          </view>
        </view>

        <!-- 搜索结果列表 -->
        <scroll-view class="major-options-list" scroll-y="true">
          <view
            class="major-option-item {{currentMajor === item.majorId ? 'selected' : ''}}"
            wx:for="{{filteredMajorList}}"
            wx:key="majorId"
            data-major-id="{{item.majorId}}"
            data-major-name="{{item.majorName}}"
            bindtap="selectMajor"
          >
            <view class="option-content">
              <text class="option-name">{{item.majorName}}</text>
              <text class="option-desc" wx:if="{{item.description}}">{{item.description}}</text>
            </view>
            <view class="option-check" wx:if="{{currentMajor === item.majorId}}">
              <text class="check-icon">✓</text>
            </view>
          </view>

          <!-- 无搜索结果提示 -->
          <view class="no-result-tip" wx:if="{{filteredMajorList.length === 0 && majorSearchKeyword}}">
            <text>未找到匹配的专业</text>
          </view>
        </scroll-view>
      </view>
    </view>
  </view>

  <!-- 科目列表 -->
  <view class="section" wx:if="{{subjectList.length > 0}}">
    <view class="section-title">科目列表</view>
    <view class="subject-list">
      <view
        class="subject-item"
        wx:for="{{subjectList}}"
        wx:key="subjectId"
        data-subject-id="{{item.subjectId}}"
        data-subject-name="{{item.subjectName}}"
        bindtap="handleSubjectClick"
      >
        <view class="subject-icon bg-primary">
          <text class="text-white">{{item.subjectName[0]}}</text>
        </view>
        <text class="subject-name">{{item.subjectName}}</text>
      </view>
    </view>
  </view>

  <!-- 无科目提示 -->
  <view class="section" wx:if="{{subjectList.length === 0 && currentMajor && !loading}}">
    <view class="empty-tip">
      <text>该专业暂无科目数据</text>
    </view>
  </view>

  <!-- 推荐卡片 -->
  <view class="section">
    <view class="section-title">今日推荐</view>
    <view class="card-list" wx:if="{{recommendCards.length > 0}}">
      <view
        class="recommend-card card"
        wx:for="{{recommendCards}}"
        wx:key="cardId"
        data-card-id="{{item.cardId}}"
        bindtap="handleCardClick"
      >
        <view class="card-header">
          <text class="subject-tag">{{item.subjectName}}</text>
        </view>
        <view class="card-content">
          <text>{{item.frontContent}}</text>
        </view>
        <view class="card-footer">
          <text class="difficulty">难度: {{item.difficultyLevel}}级</text>
          <text class="hint text-primary">点击查看答案</text>
        </view>
      </view>
    </view>
    <view class="empty-tip" wx:else>
      <text>暂无推荐卡片</text>
    </view>
  </view>
</view>