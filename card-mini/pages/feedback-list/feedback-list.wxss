/* pages/feedback-list/feedback-list.wxss */
.feedback-list-page {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 空提示 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 128rpx 32rpx;
}

.empty-icon {
  font-size: 96rpx;
  margin-bottom: 32rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #909399;
  margin-bottom: 32rpx;
}

.login-btn,
.add-btn {
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 64rpx;
  font-size: 28rpx;
}

/* 反馈列表 */
.feedback-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.feedback-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.feedback-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.type-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.type-tag.SUGGESTION {
  background: #ecf5ff;
  color: #409eff;
}

.type-tag.ERROR {
  background: #fef0f0;
  color: #f56c6c;
}

.type-tag.FUNCTION {
  background: #fdf6ec;
  color: #e6a23c;
}

.type-tag.OTHER {
  background: #f4f4f5;
  color: #909399;
}

.status-tag {
  font-size: 24rpx;
  padding: 8rpx 16rpx;
  border-radius: 4rpx;
}

.status-tag.status-0 {
  background: #fdf6ec;
  color: #e6a23c;
}

.status-tag.status-1 {
  background: #f0f9eb;
  color: #67c23a;
}

.status-tag.status-2 {
  background: #f4f4f5;
  color: #909399;
}

.feedback-content {
  font-size: 28rpx;
  color: #303133;
  line-height: 1.5;
  margin-bottom: 16rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.feedback-card {
  font-size: 24rpx;
  color: #909399;
  margin-bottom: 16rpx;
}

.card-label {
  margin-right: 8rpx;
}

.card-id {
  color: #409eff;
}

.feedback-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.feedback-time {
  font-size: 24rpx;
  color: #909399;
}

.feedback-rating {
  display: flex;
}

.star {
  font-size: 24rpx;
  color: #dcdfe6;
}

.star.active {
  color: #f7ba2a;
}

.admin-reply {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ebeef5;
}

.reply-label {
  font-size: 24rpx;
  color: #67c23a;
  margin-bottom: 8rpx;
}

.reply-content {
  font-size: 26rpx;
  color: #606266;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 128rpx 32rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 32rpx;
  color: #909399;
  font-size: 28rpx;
}