/* pages/study/study.wxss */

.container {
  min-height: 100vh;
  background-color: #f5f7fa;
  padding-bottom: 100rpx;
}

/* 头部区域 */
.header {
  position: relative;
  padding: 40rpx 30rpx 60rpx;
  margin-bottom: -30rpx;
}

.header-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.header-content {
  position: relative;
  z-index: 1;
}

.subject-title {
  font-size: 42rpx;
  font-weight: 600;
  color: #fff;
  display: block;
  margin-bottom: 24rpx;
}

.stats-row {
  display: flex;
  justify-content: space-around;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 20rpx 10rpx;
}

.stat-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.stat-value.success {
  color: #43e97b;
}

.stat-value.warning {
  color: #ffd700;
}

.stat-value.muted {
  color: rgba(255, 255, 255, 0.8);
}

.stat-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 6rpx;
}

/* 错误状态 */
.error-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 30rpx;
  margin-top: 60rpx;
}

.error-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.error-text {
  font-size: 32rpx;
  color: #606266;
  margin-bottom: 30rpx;
  text-align: center;
}

.error-actions {
  display: flex;
  gap: 20rpx;
}

.retry-btn, .home-btn {
  padding: 20rpx 40rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
}

.home-btn {
  background-color: #f5f7fa;
  color: #606266;
}

/* 快速开始按钮 */
.quick-start {
  padding: 20rpx 30rpx;
}

/* 搜索区域 */
.search-section {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 16rpx 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #303133;
}

.clear-icon {
  font-size: 28rpx;
  color: #909399;
  padding: 4rpx;
}

.search-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 16rpx 32rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(102, 126, 234, 0.3);
}

.start-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 10rpx 30rpx rgba(67, 233, 123, 0.3);
}

.start-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.start-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.start-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 筛选标签 */
.filter-bar {
  padding: 20rpx 30rpx;
  background-color: #fff;
  margin: 0 30rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.tabs {
  display: flex;
  justify-content: space-around;
}

.tab-item {
  padding: 16rpx 24rpx;
  border-radius: 12rpx;
  background-color: #f5f7fa;
  color: #606266;
  font-size: 26rpx;
  transition: all 0.3s ease;
}

.tab-item.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  font-weight: 500;
}

/* 加载状态 */
.loading-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 30rpx;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #f5f7fa;
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: #909399;
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 卡片区域 */
.card-section {
  padding: 30rpx;
}

.card-item {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: transform 0.2s ease;
}

.card-item:active {
  transform: scale(0.98);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.difficulty-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.difficulty-badge.easy {
  background-color: #e8f5e9;
  color: #4caf50;
}

.difficulty-badge.medium {
  background-color: #fff3e0;
  color: #ff9800;
}

.difficulty-badge.hard {
  background-color: #ffebee;
  color: #f44336;
}

.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.status-badge.mastered {
  background-color: #e8f5e9;
  color: #4caf50;
}

.status-badge.fuzzy {
  background-color: #fff8e1;
  color: #ffc107;
}

.status-badge.unlearned {
  background-color: #f5f5f5;
  color: #9e9e9e;
}

.card-content {
  padding: 16rpx 0;
}

.card-text {
  font-size: 30rpx;
  line-height: 1.6;
  color: #303133;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ebeef5;
}

.card-info {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-subject {
  font-size: 22rpx;
  color: #667eea;
  background-color: #f0f5ff;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.card-id {
  font-size: 22rpx;
  color: #909399;
}

.view-hint {
  font-size: 24rpx;
  color: #667eea;
}

/* 标签 */
.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 16rpx;
}

.tag {
  font-size: 22rpx;
  color: #909399;
  background-color: #f5f7fa;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

/* 加载更多 */
.load-more {
  padding: 32rpx;
  text-align: center;
}

.load-text {
  color: #667eea;
  font-size: 28rpx;
}

/* 已加载全部 */
.all-loaded {
  padding: 32rpx;
  text-align: center;
}

.all-loaded-text {
  color: #909399;
  font-size: 26rpx;
}

/* 空状态 */
.empty {
  padding: 100rpx 30rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  color: #606266;
  font-size: 32rpx;
  margin-bottom: 12rpx;
}

.empty-hint {
  color: #909399;
  font-size: 26rpx;
}