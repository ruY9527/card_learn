/* pages/add-card/add-card.wxss */

.container {
  min-height: 100vh;
  background-color: #F5F5F5;
  padding-bottom: 120rpx;
}

/* 顶部提示 */
.header {
  padding: 32rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header-icon {
  width: 80rpx;
  height: 80rpx;
  font-size: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
  margin-bottom: 16rpx;
}

.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

/* 表单区域 */
.form-section {
  padding: 24rpx 32rpx;
}

.form-item {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.form-label {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.label-text {
  font-size: 28rpx;
  color: #303133;
  font-weight: 500;
}

.label-required {
  font-size: 24rpx;
  color: #F56C6C;
  margin-left: 8rpx;
}

.label-optional {
  font-size: 24rpx;
  color: #909399;
  margin-left: 8rpx;
}

/* 选择器样式 */
.picker-box {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  border: 2rpx solid #E4E7ED;
  transition: all 0.3s ease;
}

.picker-box.selected {
  background-color: #ECF5FF;
  border-color: #409EFF;
}

.picker-box.disabled {
  background-color: #F5F5F5;
  opacity: 0.6;
}

.picker-text {
  font-size: 28rpx;
  color: #909399;
}

.picker-box.selected .picker-text {
  color: #409EFF;
  font-weight: 500;
}

.picker-arrow {
  font-size: 24rpx;
  color: #C0C4CC;
}

/* 提示文字 */
.picker-tip {
  margin-top: 12rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #E6A23C;
}

/* 内容输入框 */
.content-input {
  width: 100%;
  min-height: 160rpx;
  padding: 16rpx;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  border: 2rpx solid #E4E7ED;
  font-size: 28rpx;
  color: #303133;
  line-height: 1.6;
  transition: all 0.3s ease;
}

.content-input.has-content {
  border-color: #409EFF;
  background-color: #FFFFFF;
}

.input-placeholder {
  color: #C0C4CC;
  font-size: 28rpx;
}

.input-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.markdown-tip {
  font-size: 22rpx;
  color: #909399;
}

.char-count {
  font-size: 22rpx;
  color: #C0C4CC;
}

/* 难度选择器 */
.difficulty-selector {
  display: flex;
  justify-content: space-between;
  gap: 12rpx;
}

.difficulty-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 20rpx 0;
  background-color: #F5F7FA;
  border-radius: 12rpx;
  border: 2rpx solid #E4E7ED;
  transition: all 0.3s ease;
}

.difficulty-item.active {
  background-color: #409EFF;
  border-color: #409EFF;
}

.difficulty-text {
  font-size: 26rpx;
  color: #606266;
}

.difficulty-item.active .difficulty-text {
  color: #FFFFFF;
  font-weight: 500;
}

/* 提交按钮区域 */
.submit-section {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border: none;
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 500;
}

.submit-btn::after {
  border: none;
}

.submit-btn.disabled {
  background: #C0C4CC;
}

.btn-content {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.loading-icon {
  width: 32rpx;
  height: 32rpx;
  border: 3rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.submit-tip {
  font-size: 24rpx;
  color: #909399;
  margin-top: 16rpx;
}