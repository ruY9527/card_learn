/* pages/progress-cards/progress-cards.wxss */

.container {
  padding: 20rpx;
  background: #f5f7fa;
  min-height: 100vh;
}

/* 统计信息 */
.stats-bar {
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.stats-text {
  font-size: 28rpx;
  color: #606266;
}

/* 卡片列表 */
.card-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.card-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.card-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-subject {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.subject-icon {
  font-size: 24rpx;
}

.subject-name {
  font-size: 26rpx;
  color: #409eff;
  font-weight: 500;
}

.card-status {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.status-mastered {
  background: rgba(103, 194, 58, 0.1);
  color: #67c23a;
}

.status-review {
  background: rgba(230, 162, 60, 0.1);
  color: #e6a23c;
}

.status-unlearned {
  background: rgba(144, 147, 153, 0.1);
  color: #909399;
}

/* 学习时间 */
.card-time {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 16rpx;
  padding: 8rpx 12rpx;
  background: rgba(64, 158, 255, 0.05);
  border-radius: 8rpx;
}

.time-icon {
  font-size: 20rpx;
}

.time-text {
  font-size: 24rpx;
  color: #409eff;
  font-weight: 500;
}

.time-label {
  font-size: 22rpx;
  color: #909399;
}

/* 卡片内容 */
.card-content {
  margin-bottom: 16rpx;
}

.content-label {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 8rpx;
}

.label-icon {
  font-size: 20rpx;
}

.label-text {
  font-size: 24rpx;
  color: #909399;
}

.content-text {
  font-size: 28rpx;
  color: #303133;
  line-height: 1.6;
  display: block;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ebeef5;
}

.card-tags {
  display: flex;
  gap: 8rpx;
  flex-wrap: wrap;
}

.tag-item {
  padding: 4rpx 12rpx;
  background: rgba(64, 158, 255, 0.1);
  border-radius: 6rpx;
  font-size: 22rpx;
  color: #409eff;
}

.card-difficulty {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.difficulty-label {
  font-size: 22rpx;
  color: #909399;
}

.difficulty-stars {
  display: flex;
}

.star {
  font-size: 22rpx;
  color: #dcdfe6;
}

.star.active {
  color: #f56c6c;
}

/* 卡片操作 */
.card-action {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #ebeef5;
  display: flex;
  justify-content: flex-end;
}

.action-text {
  font-size: 26rpx;
  color: #409eff;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #e4e7ed;
  border-top-color: #409eff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #909399;
  margin-top: 16rpx;
}

/* 无更多数据 */
.no-more {
  text-align: center;
  padding: 30rpx;
  font-size: 26rpx;
  color: #909399;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #606266;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #909399;
}