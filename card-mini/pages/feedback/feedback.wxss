/* pages/feedback/feedback.wxss */
.feedback-page {
  padding: 32rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

/* 登录提示 */
.login-tip {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
  color: #fff;
}

.tip-content {
  margin-bottom: 32rpx;
}

.tip-icon {
  font-size: 64rpx;
  display: block;
  margin-bottom: 16rpx;
}

.tip-text {
  font-size: 32rpx;
  font-weight: bold;
  display: block;
}

.tip-desc {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
}

.login-btn {
  background: #fff;
  color: #667eea;
  border: none;
  border-radius: 40rpx;
  padding: 24rpx 64rpx;
  font-size: 28rpx;
  font-weight: bold;
}

/* 卡片信息 */
.card-info {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

.card-label {
  font-size: 24rpx;
  color: #909399;
  margin-bottom: 8rpx;
}

.card-content {
  font-size: 28rpx;
  color: #303133;
  line-height: 1.5;
}

/* 表单项 */
.feedback-form {
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx;
}

.form-item {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: #303133;
  font-weight: bold;
  margin-bottom: 16rpx;
}

/* 必填标识 */
.required {
  color: #f56c6c;
  font-size: 24rpx;
  margin-left: 4rpx;
}

/* 选择器 */
.picker-value {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

.picker-arrow {
  color: #909399;
  font-size: 24rpx;
}

/* 评分 */
.rating-box {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.star {
  font-size: 48rpx;
  color: #dcdfe6;
}

.star.active {
  color: #f7ba2a;
}

.rating-text {
  font-size: 24rpx;
  color: #909399;
  margin-left: 16rpx;
}

/* 内容输入 */
.content-input {
  width: 100%;
  height: 240rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  line-height: 1.5;
}

.content-count {
  text-align: right;
  font-size: 24rpx;
  color: #909399;
  margin-top: 8rpx;
}

/* 联系方式输入 */
.contact-input {
  width: 100%;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
}

/* 图片上传 */
.image-upload {
  display: flex;
  gap: 16rpx;
}

.image-item {
  width: 160rpx;
  height: 160rpx;
  position: relative;
}

.image-item image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.remove-btn {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 32rpx;
  height: 32rpx;
  background: #f56c6c;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 32rpx;
  font-size: 24rpx;
}

.upload-btn {
  width: 160rpx;
  height: 160rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.upload-icon {
  font-size: 48rpx;
  color: #909399;
}

.upload-text {
  font-size: 24rpx;
  color: #909399;
  margin-top: 8rpx;
}

.image-tip {
  font-size: 24rpx;
  color: #909399;
  margin-top: 8rpx;
}

/* 提交按钮 */
.submit-btn {
  width: 100%;
  background: linear-gradient(135deg, #409eff 0%, #66b1ff 100%);
  color: #fff;
  border: none;
  border-radius: 40rpx;
  padding: 32rpx;
  font-size: 32rpx;
  font-weight: bold;
  margin-top: 32rpx;
}

.submit-btn[disabled] {
  background: #dcdfe6;
}

/* 历史反馈入口 */
.history-entry {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 12rpx;
  padding: 32rpx;
  margin-top: 32rpx;
}

.history-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}

.history-text {
  font-size: 28rpx;
  color: #303133;
  flex: 1;
}

.history-arrow {
  font-size: 28rpx;
  color: #909399;
}