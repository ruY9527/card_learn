<!--pages/feedback/feedback.wxml-->
<view class="feedback-page">
  <!-- 登录提示 -->
  <view class="login-tip" wx:if="{{!isLoggedIn}}">
    <view class="tip-content">
      <text class="tip-icon">🔒</text>
      <text class="tip-text">提交反馈需要先登录</text>
      <text class="tip-desc">登录后可以更好地追踪反馈处理进度</text>
    </view>
    <button class="login-btn" bindtap="goLogin">去登录</button>
  </view>

  <!-- 反馈表单 -->
  <view class="feedback-form" wx:if="{{isLoggedIn}}">
    <!-- 卡片纠错信息 -->
    <view class="card-info" wx:if="{{cardId}}">
      <view class="card-label">关联卡片</view>
      <view class="card-content">{{cardFrontContent}}</view>
    </view>

    <!-- 专业选择 -->
    <view class="form-item">
      <view class="form-label">选择专业<text class="required">*</text></view>
      <picker mode="selector" range="{{majorList}}" range-key="majorName" value="{{majorIndex}}" bindchange="onMajorChange">
        <view class="picker-value">
          <text>{{majorList[majorIndex].majorName || '请选择专业'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 科目选择 -->
    <view class="form-item">
      <view class="form-label">选择科目<text class="required">*</text></view>
      <picker mode="selector" range="{{subjectList}}" range-key="subjectName" value="{{subjectIndex}}" bindchange="onSubjectChange">
        <view class="picker-value">
          <text>{{subjectList[subjectIndex].subjectName || '请先选择专业'}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 反馈类型 -->
    <view class="form-item">
      <view class="form-label">反馈类型</view>
      <picker mode="selector" range="{{typeOptions}}" range-key="label" value="{{typeIndex}}" bindchange="onTypeChange">
        <view class="picker-value">
          <text>{{typeOptions[typeIndex].label}}</text>
          <text class="picker-arrow">▼</text>
        </view>
      </picker>
    </view>

    <!-- 评分 -->
    <view class="form-item">
      <view class="form-label">评分（可选）</view>
      <view class="rating-box">
        <block wx:for="{{[1,2,3,4,5]}}" wx:key="*this">
          <text class="star {{rating >= item ? 'active' : ''}}" bindtap="onRatingTap" data-rating="{{item}}">★</text>
        </block>
        <text class="rating-text" wx:if="{{rating}}">{{rating}}星</text>
      </view>
    </view>

    <!-- 反馈内容 -->
    <view class="form-item">
      <view class="form-label">反馈内容<text class="required">*</text></view>
      <textarea class="content-input" placeholder="请详细描述您的反馈内容..." value="{{content}}" bindinput="onContentInput" maxlength="500" />
      <view class="content-count">{{content.length}}/500</view>
    </view>

    <!-- 联系方式 -->
    <view class="form-item">
      <view class="form-label">联系方式（可选）</view>
      <input class="contact-input" placeholder="留下您的联系方式，方便我们回复" value="{{contact}}" bindinput="onContactInput" />
    </view>

    <!-- 图片上传 -->
    <view class="form-item">
      <view class="form-label">图片附件（可选）</view>
      <view class="image-upload">
        <block wx:for="{{images}}" wx:key="*this">
          <view class="image-item">
            <image src="{{item}}" mode="aspectFill" bindtap="previewImage" data-url="{{item}}" />
            <text class="remove-btn" bindtap="removeImage" data-index="{{index}}">×</text>
          </view>
        </block>
        <view class="upload-btn" wx:if="{{images.length < 3}}" bindtap="chooseImage">
          <text class="upload-icon">+</text>
          <text class="upload-text">上传图片</text>
        </view>
      </view>
      <view class="image-tip">最多上传3张图片</view>
    </view>

    <!-- 提交按钮 -->
    <button class="submit-btn" bindtap="submitFeedback" disabled="{{!canSubmit || submitting}}">
      {{submitting ? '提交中...' : '提交反馈'}}
    </button>
  </view>

  <!-- 历史反馈入口 -->
  <view class="history-entry" wx:if="{{isLoggedIn}}" bindtap="goFeedbackList">
    <text class="history-icon">📋</text>
    <text class="history-text">查看我的反馈记录</text>
    <text class="history-arrow">→</text>
  </view>
</view>