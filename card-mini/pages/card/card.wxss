/* pages/card/card.wxss - 增强版卡片样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  display: flex;
  flex-direction: column;
  padding: 0;
}

/* 顶部导航栏 */
.nav-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.1);
}

.nav-back, .nav-forward {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.2);
}

.nav-icon {
  color: #fff;
  font-size: 36rpx;
}

.nav-title {
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
}

/* 进度指示器 */
.progress-indicator {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 0;
}

.progress-dots {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background-color: rgba(255, 255, 255, 0.3);
  transition: all 0.3s ease;
}

.dot.active {
  background-color: #fff;
  transform: scale(1.2);
}

.more-dots {
  color: rgba(255, 255, 255, 0.6);
  font-size: 24rpx;
  margin-left: 8rpx;
}

.progress-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  margin-top: 10rpx;
}

/* 加载状态 */
.loading-container {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #fff;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  margin-top: 20rpx;
}

/* 卡片滑动区域 */
.card-swipe-area {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  padding: 30rpx;
}

/* 滑动提示 */
.swipe-hint {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  padding: 20rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.9);
  border-radius: 12rpx;
  color: #667eea;
  font-size: 28rpx;
  font-weight: 500;
  opacity: 0;
  transition: opacity 0.3s ease;
  z-index: 100;
}

.swipe-hint.left {
  left: 30rpx;
}

.swipe-hint.right {
  right: 30rpx;
}

.swipe-hint.show {
  opacity: 1;
}

/* 卡片容器 */
.card-container {
  width: 100%;
  transition: transform 0.1s ease-out;
}

/* 3D翻转卡片 - 增加高度 */
.flip-card {
  width: 100%;
  height: 550rpx;
  perspective: 1000rpx;
  position: relative;
  transform-style: preserve-3d;
  transition: transform 0.6s cubic-bezier(0.4, 0.0, 0.2, 1);
}

.flip-card.flipped {
  transform: rotateY(180deg);
}

/* 卡片正反面共同样式 */
.flip-card-front,
.flip-card-back {
  position: absolute;
  width: 100%;
  height: 100%;
  backface-visibility: hidden;
  border-radius: 24rpx;
  background-color: #fff;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.15);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.flip-card-back {
  transform: rotateY(180deg);
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 30rpx;
  border-bottom: 1rpx solid rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.card-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
}

.card-badge.success {
  background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%);
}

.badge-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 500;
}

.card-difficulty {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.difficulty-label {
  color: #909399;
  font-size: 24rpx;
}

.difficulty-stars {
  display: flex;
}

.star {
  color: #dcdfe6;
  font-size: 24rpx;
}

.star.active {
  color: #f56c6c;
}

/* 卡片内容区域 - 使用 scroll-view */
.card-body {
  flex: 1;
  height: 400rpx;
  overflow: hidden;
}

.answer-body {
  /* 答案区域样式 */
}

.card-content-wrapper {
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  min-height: 100%;
}

.card-content {
  font-size: 32rpx;
  line-height: 1.8;
  color: #303133;
  word-break: break-word;
}

/* 卡片底部 */
.card-footer {
  padding: 24rpx 30rpx;
  display: flex;
  justify-content: center;
  border-top: 1rpx solid rgba(0, 0, 0, 0.05);
  flex-shrink: 0;
}

.flip-hint {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.hint-icon {
  font-size: 28rpx;
}

.hint-text {
  color: #909399;
  font-size: 26rpx;
}

/* 标签区域 */
.tags-section {
  padding: 20rpx 30rpx;
}

.tags-container {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  padding: 10rpx 20rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
  color: #fff;
  font-size: 24rpx;
}

/* 学习状态按钮 */
.status-buttons {
  display: flex;
  justify-content: center;
  gap: 40rpx;
  padding: 40rpx 30rpx;
  background-color: rgba(255, 255, 255, 0.1);
  margin: 20rpx 30rpx;
  border-radius: 24rpx;
}

.status-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  transition: transform 0.2s ease;
}

.status-btn:active {
  transform: scale(0.95);
}

.btn-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.2);
}

.status-btn.unlearned .btn-icon {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
}

.status-btn.fuzzy .btn-icon {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}

.status-btn.mastered .btn-icon {
  background: linear-gradient(135deg, #43e97b 0%, #38f9d7 100%);
}

.icon-text {
  color: #fff;
  font-size: 48rpx;
  font-weight: bold;
}

.btn-label {
  color: #fff;
  font-size: 26rpx;
}

/* 底部进度条 */
.bottom-progress {
  padding: 30rpx;
  background-color: rgba(255, 255, 255, 0.1);
}

.progress-bar-track {
  height: 12rpx;
  background-color: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #43e97b 0%, #38f9d7 100%);
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.progress-labels {
  display: flex;
  justify-content: space-between;
  margin-top: 16rpx;
}

.progress-percent {
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.progress-remain {
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
}

/* 滑动动画效果 */
.card-swipe-area.swiping-left .card-container {
  animation: swipeLeftHint 0.3s ease;
}

.card-swipe-area.swiping-right .card-container {
  animation: swipeRightHint 0.3s ease;
}

@keyframes swipeLeftHint {
  0% { transform: translateX(0); }
  50% { transform: translateX(-30rpx); }
  100% { transform: translateX(0); }
}

@keyframes swipeRightHint {
  0% { transform: translateX(0); }
  50% { transform: translateX(30rpx); }
  100% { transform: translateX(0); }
}