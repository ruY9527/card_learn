<!--pages/card/card.wxml-->
<view class="container">
  <!-- 顶部导航栏 -->
  <view class="nav-bar">
    <view class="nav-back" bindtap="handlePrev">
      <text class="nav-icon">←</text>
    </view>
    <view class="nav-title">
      <text>{{subjectName || '知识点学习'}}</text>
    </view>
    <view class="nav-forward" bindtap="handleNext">
      <text class="nav-icon">→</text>
    </view>
  </view>

  <!-- 进度指示器 -->
  <view class="progress-indicator">
    <view class="progress-dots">
      <view class="dot {{currentIndex >= index ? 'active' : ''}}" wx:for="{{totalCount}}" wx:key="index" wx:if="{{index < 10}}"></view>
      <text class="more-dots" wx:if="{{totalCount > 10}}">...</text>
    </view>
    <view class="progress-text">
      <text>{{currentIndex + 1}} / {{totalCount}}</text>
    </view>
  </view>

  <!-- 加载状态 -->
  <view class="loading-container" wx:if="{{!currentCard}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 卡片滑动区域 -->
  <view
    class="card-swipe-area"
    wx:if="{{currentCard}}"
    bindtouchstart="onTouchStart"
    bindtouchmove="onTouchMove"
    bindtouchend="onTouchEnd"
  >
    <!-- 滑动提示 -->
    <view class="swipe-hint left" wx:if="{{isSwiping && moveX > 50 && currentIndex > 0}}">
      <text>← 上一张</text>
    </view>
    <view class="swipe-hint right" wx:if="{{isSwiping && moveX < -50}}">
      <text>下一张 →</text>
    </view>

    <!-- 卡片容器 -->
    <view class="card-container" style="transform: translateX({{moveX}}px);">
      <!-- 3D翻转卡片 -->
      <view class="flip-card {{isFlipped ? 'flipped' : ''}}" bindtap="toggleFlip">
        <!-- 卡片正面 -->
        <view class="flip-card-front">
          <view class="card-header">
            <view class="card-badge">
              <text class="badge-text">问题</text>
            </view>
            <view class="card-difficulty">
              <text class="difficulty-label">难度</text>
              <view class="difficulty-stars">
                <text class="star {{item <= currentCard.difficultyLevel ? 'active' : ''}}" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">★</text>
              </view>
            </view>
          </view>

          <!-- 正面内容区域 - 支持滚动 -->
          <scroll-view class="card-body" scroll-y="true" enhanced="true" show-scrollbar="false">
            <view class="card-content-wrapper">
              <markdown-render content="{{currentCard.frontContent}}"></markdown-render>
            </view>
          </scroll-view>

          <view class="card-footer">
            <view class="flip-hint">
              <text class="hint-icon">👆</text>
              <text class="hint-text">点击翻转查看答案</text>
            </view>
          </view>
        </view>

        <!-- 卡片反面 -->
        <view class="flip-card-back">
          <view class="card-header">
            <view class="card-badge success">
              <text class="badge-text">答案</text>
            </view>
            <view class="card-difficulty">
              <text class="difficulty-label">难度</text>
              <view class="difficulty-stars">
                <text class="star {{item <= currentCard.difficultyLevel ? 'active' : ''}}" wx:for="{{[1,2,3,4,5]}}" wx:key="*this">★</text>
              </view>
            </view>
          </view>

          <!-- 答案内容区域 - 支持滚动 -->
          <scroll-view class="card-body answer-body" scroll-y="true" enhanced="true" show-scrollbar="false">
            <view class="card-content-wrapper">
              <markdown-render content="{{currentCard.backContent}}"></markdown-render>
            </view>
          </scroll-view>

          <view class="card-footer">
            <view class="flip-hint">
              <text class="hint-icon">👆</text>
              <text class="hint-text">点击返回问题</text>
            </view>
            <view class="feedback-btn" catchtap="goFeedback">
              <text class="feedback-icon">📝</text>
              <text class="feedback-text">纠错反馈</text>
            </view>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 标签展示 -->
  <view class="tags-section" wx:if="{{currentCard && currentCard.tags && currentCard.tags.length > 0}}">
    <view class="tags-container">
      <view class="tag-item" wx:for="{{currentCard.tags}}" wx:key="*this">
        <text>{{item}}</text>
      </view>
    </view>
  </view>

  <!-- 评论入口 -->
  <view class="comment-section" wx:if="{{currentCard}}">
    <view class="comment-stats" bindtap="showComments">
      <text class="comment-icon">💬</text>
      <text class="comment-count">{{commentStats.totalComments || 0}}条评论</text>
      <view class="quality-badge" wx:if="{{commentStats.qualityCount > 0}}">
        <text class="quality-icon">👍</text>
        <text class="quality-count">{{commentStats.qualityCount}}</text>
      </view>
      <view class="poor-badge" wx:if="{{commentStats.poorCount > 0}}">
        <text class="poor-icon">👎</text>
        <text class="poor-count">{{commentStats.poorCount}}</text>
      </view>
      <text class="comment-arrow">→</text>
    </view>
    <view class="add-comment-btn" bindtap="showCommentModal">
      <text class="add-icon">✏️</text>
      <text class="add-text">评价</text>
    </view>
  </view>

  <!-- 学习状态按钮 -->
  <view class="status-buttons" wx:if="{{isFlipped && currentCard}}">
    <view class="status-btn unlearned" data-status="0" bindtap="handleStatus">
      <view class="btn-icon">
        <text class="icon-text">✗</text>
      </view>
      <text class="btn-label">不熟</text>
    </view>

    <view class="status-btn fuzzy" data-status="1" bindtap="handleStatus">
      <view class="btn-icon">
        <text class="icon-text">~</text>
      </view>
      <text class="btn-label">模糊</text>
    </view>

    <view class="status-btn mastered" data-status="2" bindtap="handleStatus">
      <view class="btn-icon">
        <text class="icon-text">✓</text>
      </view>
      <text class="btn-label">掌握</text>
    </view>
  </view>

  <!-- 底部进度条 -->
  <view class="bottom-progress" wx:if="{{currentCard}}">
    <view class="progress-bar-track">
      <view class="progress-bar-fill" style="width: {{progress}}%;"></view>
    </view>
    <view class="progress-labels">
      <text class="progress-percent">{{progress}}%</text>
      <text class="progress-remain">剩余 {{totalCount - currentIndex - 1}} 张</text>
    </view>
  </view>

  <!-- 评论弹窗 -->
  <view class="comment-modal" wx:if="{{showCommentDialog}}">
    <view class="modal-mask" bindtap="hideCommentModal"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">评价知识点</text>
        <text class="modal-close" bindtap="hideCommentModal">✕</text>
      </view>

      <view class="modal-body">
        <!-- 评论类型 -->
        <view class="comment-type-section">
          <text class="section-label">内容质量</text>
          <view class="type-options">
            <view class="type-option {{commentType === 'QUALITY' ? 'active quality' : ''}}" data-type="QUALITY" bindtap="selectCommentType">
              <text class="type-icon">👍</text>
              <text class="type-text">优质内容</text>
            </view>
            <view class="type-option {{commentType === 'NEUTRAL' ? 'active' : ''}}" data-type="NEUTRAL" bindtap="selectCommentType">
              <text class="type-icon">😐</text>
              <text class="type-text">一般</text>
            </view>
            <view class="type-option {{commentType === 'POOR' ? 'active poor' : ''}}" data-type="POOR" bindtap="selectCommentType">
              <text class="type-icon">👎</text>
              <text class="type-text">劣质内容</text>
            </view>
          </view>
        </view>

        <!-- 评分 -->
        <view class="rating-section">
          <text class="section-label">评分</text>
          <view class="rating-stars">
            <text class="rating-star {{index < rating ? 'active' : ''}}" wx:for="{{[1,2,3,4,5]}}" wx:key="*this" data-rating="{{item}}" bindtap="setRating">★</text>
          </view>
          <text class="rating-text">{{rating}}星</text>
        </view>

        <!-- 评论内容 -->
        <view class="content-section">
          <text class="section-label">评价内容（可选）</text>
          <textarea class="comment-input" placeholder="请输入您的评价或建议..." value="{{commentContent}}" bindinput="onCommentInput" maxlength="200"></textarea>
        </view>

        <!-- 保存为笔记 -->
        <view class="note-section">
          <checkbox class="note-checkbox" checked="{{saveAsNote}}" bindchange="toggleSaveAsNote" color="#409EFF" />
          <text class="note-label" bindtap="toggleSaveAsNote">同时保存为笔记</text>
        </view>
      </view>

      <view class="modal-footer">
        <view class="cancel-btn" bindtap="hideCommentModal">取消</view>
        <view class="submit-btn {{canSubmit ? '' : 'disabled'}}" bindtap="submitComment">提交评价</view>
      </view>
    </view>
  </view>
</view>