.container {
  padding: 20rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.comment-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
}

.comment-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.nickname {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.time {
  font-size: 22rpx;
  color: #999;
}

.comment-type {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.type-quality {
  background: #e6f7e6;
  color: #52c41a;
}

.type-poor {
  background: #fff1f0;
  color: #ff4d4f;
}

.type-neutral {
  background: #f0f0f0;
  color: #999;
}

.rating {
  margin-bottom: 12rpx;
}

.star {
  font-size: 28rpx;
  color: #ddd;
}

.star-active {
  color: #ffc107;
}

.comment-content {
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.comment-actions {
  display: flex;
  gap: 32rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.action-btn {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.action-icon {
  font-size: 28rpx;
  color: #999;
}

.action-icon.liked {
  color: #ff4d4f;
}

.action-text {
  font-size: 22rpx;
  color: #999;
}

/* 回复区域 */
.replies-section {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.reply-loading {
  text-align: center;
  padding: 20rpx;
  color: #999;
  font-size: 24rpx;
}

.reply-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f8f8f8;
}

.reply-item:last-child {
  border-bottom: none;
}

.reply-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.reply-nickname {
  font-size: 24rpx;
  font-weight: 600;
  color: #333;
}

.reply-time {
  font-size: 20rpx;
  color: #999;
}

.reply-content {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
  margin-bottom: 8rpx;
}

.reply-actions {
  display: flex;
  gap: 24rpx;
}

.children-section {
  margin-top: 12rpx;
  padding-left: 24rpx;
}

.load-children-btn {
  font-size: 22rpx;
  color: #1890ff;
  padding: 8rpx 0;
}

.children-list {
  margin-top: 8rpx;
  padding-left: 24rpx;
}

.child-reply {
  padding: 8rpx 0;
  font-size: 24rpx;
}

.child-nickname {
  color: #1890ff;
  margin-right: 8rpx;
}

.child-content {
  color: #333;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #999;
}

.loading-more, .no-more {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
}

/* 回复弹窗 */
.reply-dialog-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: flex-end;
  z-index: 1000;
}

.reply-dialog {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx;
}

.dialog-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.dialog-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.dialog-close {
  font-size: 36rpx;
  color: #999;
  padding: 8rpx;
}

.reply-input {
  width: 100%;
  height: 200rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 16rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.dialog-footer {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-end;
}

.submit-btn {
  background: #1890ff;
  color: #fff;
  font-size: 28rpx;
  padding: 12rpx 48rpx;
  border-radius: 8rpx;
  border: none;
}
