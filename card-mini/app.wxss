/* app.wxss - 全局样式 */

/* 主色调 */
.primary {
  color: #409EFF;
}

.bg-primary {
  background-color: #409EFF;
}

/* 成功色 */
.success {
  color: #67C23A;
}

.bg-success {
  background-color: #67C23A;
}

/* 警告色 */
.warning {
  color: #E6A23C;
}

.bg-warning {
  background-color: #E6A23C;
}

/* 错误色 */
.danger {
  color: #F56C6C;
}

.bg-danger {
  background-color: #F56C6C;
}

/* 信息色 */
.info {
  color: #909399;
}

.bg-gray {
  background-color: #F5F5F5;
}

/* 卡片样式 */
.card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

/* 文字大小 */
.text-xs {
  font-size: 24rpx;
}

.text-sm {
  font-size: 28rpx;
}

.text-base {
  font-size: 32rpx;
}

.text-lg {
  font-size: 36rpx;
}

.text-xl {
  font-size: 40rpx;
}

/* 文字粗细 */
.font-bold {
  font-weight: bold;
}

/* 边距 */
.p-4 {
  padding: 32rpx;
}

.mt-4 {
  margin-top: 32rpx;
}

.mb-4 {
  margin-bottom: 32rpx;
}

.ml-4 {
  margin-left: 32rpx;
}

/* Flex布局 */
.flex {
  display: flex;
}

.flex-col {
  flex-direction: column;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.justify-between {
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* 圆角 */
.rounded-lg {
  border-radius: 16rpx;
}

.rounded-full {
  border-radius: 9999rpx;
}

/* 文字颜色 */
.text-white {
  color: #FFFFFF;
}

.text-gray {
  color: #909399;
}

.text-primary {
  color: #409EFF;
}

.text-success {
  color: #67C23A;
}

.text-warning {
  color: #E6A23C;
}

.text-danger {
  color: #F56C6C;
}

/* 宽度 - 使用合法类名 */
.w-half {
  width: 50%;
}

.w-third {
  width: 33.333%;
}

.w-quarter {
  width: 25%;
}

/* 全局页面样式 */
page {
  background-color: #F5F5F5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
  font-size: 32rpx;
  color: #303133;
  line-height: 1.5;
}