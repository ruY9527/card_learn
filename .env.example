# ==================== Docker Compose 环境配置 ====================
# 复制此文件为 .env 并修改相应配置

# ==================== 版本配置 ====================
VERSION=1.0.0

# ==================== MySQL 配置 ====================
MYSQL_ROOT_PASSWORD=123456
MYSQL_PORT=3306

# ==================== Redis 配置 ====================
REDIS_PORT=6379

# ==================== 后端配置 ====================
BACKEND_PORT=8080
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseG1GC

# ==================== 管理后台前端配置 ====================
WEB_PORT=80