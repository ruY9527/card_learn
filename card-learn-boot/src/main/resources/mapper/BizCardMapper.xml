<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.card.learn.mapper.BizCardMapper">

    <resultMap id="CardVOResultMap" type="com.card.learn.vo.CardVO">
        <id property="cardId" column="card_id"/>
        <result property="subjectId" column="subject_id"/>
        <result property="subjectName" column="subject_name"/>
        <result property="frontContent" column="front_content"/>
        <result property="backContent" column="back_content"/>
        <result property="difficultyLevel" column="difficulty_level"/>
        <result property="auditStatus" column="audit_status"/>
        <result property="auditStatusText" column="audit_status_text"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createUserNickname" column="create_user_nickname"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <resultMap id="CardAuditVOResultMap" type="com.card.learn.vo.CardAuditVO">
        <id property="cardId" column="card_id"/>
        <result property="subjectId" column="subject_id"/>
        <result property="subjectName" column="subject_name"/>
        <result property="frontContent" column="front_content"/>
        <result property="backContent" column="back_content"/>
        <result property="difficultyLevel" column="difficulty_level"/>
        <result property="auditStatus" column="audit_status"/>
        <result property="auditStatusText" column="audit_status_text"/>
        <result property="createUserId" column="create_user_id"/>
        <result property="createUserNickname" column="create_user_nickname"/>
        <result property="auditUserId" column="audit_user_id"/>
        <result property="auditUserNickname" column="audit_user_nickname"/>
        <result property="auditTime" column="audit_time"/>
        <result property="auditRemark" column="audit_remark"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <resultMap id="MyCardVOResultMap" type="com.card.learn.vo.MyCardVO">
        <id property="cardId" column="card_id"/>
        <result property="subjectId" column="subject_id"/>
        <result property="subjectName" column="subject_name"/>
        <result property="frontContent" column="front_content"/>
        <result property="backContent" column="back_content"/>
        <result property="difficultyLevel" column="difficulty_level"/>
        <result property="auditStatus" column="audit_status"/>
        <result property="auditStatusText" column="audit_status_text"/>
        <result property="auditRemark" column="audit_remark"/>
        <result property="createTime" column="create_time"/>
        <result property="auditTime" column="audit_time"/>
    </resultMap>

    <select id="selectCardsWithSubjectName" resultMap="CardVOResultMap">
        SELECT
            c.card_id,
            c.subject_id,
            s.subject_name,
            c.front_content,
            c.back_content,
            c.difficulty_level,
            c.audit_status,
            CASE c.audit_status
                WHEN '0' THEN '待审批'
                WHEN '1' THEN '已通过'
                WHEN '2' THEN '已拒绝'
                ELSE '未知'
            END AS audit_status_text,
            c.create_user_id,
            au.nickname AS create_user_nickname,
            c.create_time,
            c.update_time
        FROM biz_card c
        LEFT JOIN biz_subject s ON c.subject_id = s.subject_id
        LEFT JOIN sys_user au ON c.create_user_id = au.user_id
        WHERE c.del_flag = '0'
        <if test="subjectId != null">
            AND c.subject_id = #{subjectId}
        </if>
        <if test="frontContent != null and frontContent != ''">
            AND c.front_content LIKE CONCAT('%', #{frontContent}, '%')
        </if>
        ORDER BY c.create_time DESC
    </select>

    <select id="selectPendingCards" resultMap="CardAuditVOResultMap">
        SELECT
            c.card_id,
            c.subject_id,
            s.subject_name,
            c.front_content,
            c.back_content,
            c.difficulty_level,
            c.audit_status,
            CASE c.audit_status
                WHEN '0' THEN '待审批'
                WHEN '1' THEN '已通过'
                WHEN '2' THEN '已拒绝'
                ELSE '未知'
            END AS audit_status_text,
            c.create_user_id,
            au.nickname AS create_user_nickname,
            c.audit_user_id,
            su.nickname AS audit_user_nickname,
            c.audit_time,
            c.audit_remark,
            c.create_time
        FROM biz_card c
        LEFT JOIN biz_subject s ON c.subject_id = s.subject_id
        LEFT JOIN sys_user au ON c.create_user_id = au.user_id
        LEFT JOIN sys_user su ON c.audit_user_id = su.user_id
        WHERE c.del_flag = '0'
        AND c.create_user_id IS NOT NULL
        <if test="auditStatus != null and auditStatus != ''">
            AND c.audit_status = #{auditStatus}
        </if>
        ORDER BY c.create_time DESC
    </select>

    <select id="selectMyCards" resultMap="MyCardVOResultMap">
        SELECT
            c.card_id,
            c.subject_id,
            s.subject_name,
            c.front_content,
            c.back_content,
            c.difficulty_level,
            c.audit_status,
            CASE c.audit_status
                WHEN '0' THEN '待审批'
                WHEN '1' THEN '已通过'
                WHEN '2' THEN '已拒绝'
                ELSE '未知'
            END AS audit_status_text,
            c.audit_remark,
            c.create_time,
            c.audit_time
        FROM biz_card c
        LEFT JOIN biz_subject s ON c.subject_id = s.subject_id
        WHERE c.del_flag = '0'
        AND c.create_user_id = #{createUserId}
        ORDER BY c.create_time DESC
    </select>

    <sql id="auditStatusCondition">
        (audit_status = '1' OR audit_status IS NULL)
    </sql>

    <select id="selectPageCardList" resultType="com.card.learn.entity.BizCard">
        SELECT * FROM biz_card
        <where>
            AND <include refid="auditStatusCondition"/>
            <if test="subjectId != null">
                AND subject_id = #{subjectId}
            </if>
            <if test="frontContent != null and frontContent != ''">
                AND front_content LIKE CONCAT('%', #{frontContent}, '%')
            </if>
        </where>
        ORDER BY card_id ASC
    </select>

</mapper>