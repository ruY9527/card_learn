<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.card.learn.mapper.SysConfigMapper">

    <select id="selectByKey" resultType="com.card.learn.entity.SysConfig">
        SELECT * FROM sys_config WHERE config_key = #{configKey}
    </select>

    <select id="selectAll" resultType="com.card.learn.entity.SysConfig">
        SELECT * FROM sys_config ORDER BY id ASC
    </select>

</mapper>
